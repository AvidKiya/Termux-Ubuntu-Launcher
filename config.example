# Avid Kiya Termux Ubuntu Launcher config
# After install, edit this file at: ~/.termux-avid-kiya/config

# Weather location for wttr.in
AK_WTTR_LOCATION="36.46,52.86"

# Name shown in banners
AK_NAME="Avid Kiya"

# proot-distro distribution name
AK_UBUNTU_DISTRO="ubuntu"

# 1 = after choosing option 1, open fish shell automatically
# This project is an upgraded version of the old Avid Kiya fish theme,
# so default is 1.
AK_AUTO_FISH_AFTER_TERMUX="1"

# 1 = colorize output with lolcat when available
# 0 = no lolcat colors
AK_USE_LOLCAT="1"

# 1 = force UTF-8 locale for box drawing characters
AK_UTF8="1"

# 1 = use old classic Avid Kiya Termux theme for option 1
AK_CLASSIC_TERMUX_THEME="1"
