# Avid Kiya Termux Ubuntu Launcher final config
# After install, this file is copied to: ~/.termux-avid-kiya/config

# Weather location for wttr.in
AK_WTTR_LOCATION="36.46,52.86"

# Name shown in banners
AK_NAME="Avid Kiya"

# proot-distro distribution name
AK_UBUNTU_DISTRO="ubuntu"

# 1 = after choosing option 1, open fish shell automatically with Oh My Fish/batman
AK_AUTO_FISH_AFTER_TERMUX="1"

# 1 = colorize output with lolcat when available
AK_USE_LOLCAT="1"

# 1 = force UTF-8 locale for box drawing characters
AK_UTF8="1"

# 0 = use final boxed TERMUX banner instead of old figlet-only banner
AK_CLASSIC_TERMUX_THEME="0"

# 1 = Termux and Ubuntu use matching style banners with different artwork
AK_MATCHED_BANNERS="1"

# 1 = install/repair MiMo Code inside Ubuntu when option 3 patches Ubuntu
AK_INSTALL_MIMO="1"

# 1 = after showing Ubuntu banner, open fish with Oh My Fish/batman
AK_AUTO_FISH_AFTER_UBUNTU="1"
# Branding
AK_AUTHOR="AvidKiya"
AK_HANDLE="@AvidKiya"
AK_REPO_URL="https://github.com/AvidKiya/Termux-Ubuntu-Launcher"
# Startup mode: ask, app, cli, web, shell
AK_STARTUP_MODE="ask"
# Local web app defaults
AK_WEB_HOST="127.0.0.1"
AK_WEB_PORT="8765"
# AI safety: official APIs/local models only. No token scraping or payment bypass.
AK_AI_MODE="official"

AK_CLI_THEME="mimo"

AK_CLI_ANIMATION="1"

AK_CLI_COMPACT="auto"

AK_MODELS_DIR="/root/.avid-devhub/models"

AK_LLAMA_SRC="/root/.avid-devhub/src/llama.cpp"

AK_LLAMA_PORT="8080"

AK_LOCAL_MODEL_PROVIDER="llama_local"
